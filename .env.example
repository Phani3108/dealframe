# DealFrame — Environment Configuration
# Copy to .env and fill in your values

# ── API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────
# Override the default from config/settings.yaml
DATABASE_URL=postgresql+asyncpg://temporalos:temporalos@localhost:5432/temporalos

# ── Pipeline Mode ─────────────────────────────────────────────────
# api   → use cloud models (GPT-4o, Claude)
# local → use local models only (Whisper + Qwen2.5-VL + fine-tuned)
TEMPORALOS_MODE=api

# ── Audio ─────────────────────────────────────────────────────────
# Whisper model size: tiny / base / small / medium / large-v3
# large-v3 recommended for production; base for fast local dev
AUDIO__WHISPER_MODEL=base
AUDIO__LANGUAGE=en

# ── Video ─────────────────────────────────────────────────────────
VIDEO__FRAME_INTERVAL_SECONDS=2
VIDEO__MAX_RESOLUTION=1024

# ── Telemetry (optional — leave blank to disable OTLP export) ─────
TELEMETRY__OTLP_ENDPOINT=
TELEMETRY__ENABLED=true
